OPENROUTER_API_KEY=sk-or-v1-...
LOCAL_MODEL_NAME=ai/devstral-small-2
REMOTE_MODEL_NAME=google/gemma-4-31b-it
LOCAL_BASE_URL=http://model-runner.docker.internal/engines/v1
REMOTE_BASE_URL=https://openrouter.ai/api/v1
APP_API_KEY="dev-key-1234"
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000

# --- Persistent Storage Paths ---
# Override to use mounted volumes or cloud paths in production.
CHECKPOINT_DB_PATH=checkpoints.sqlite
CHROMA_DB_PATH=chroma_db

# --- Observability (OpenTelemetry) ---
# Set to "otlp" to ship spans to Jaeger (requires docker-compose Jaeger service).
# Set to "console" (default) for local stdout output.
OTEL_EXPORTER_TYPE=console
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Human-in-the-Loop Gate ---
# Set to "true" to activate approval interrupt for save_memory_tool calls.
# When enabled, the graph pauses until Command(resume={"approved": True}) is sent.
HITL_ENABLED=false
